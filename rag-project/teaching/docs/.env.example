# ============================================
# RAG 企业知识库 — 配置模板
# Copy 为 .env 并填入你的 Key
# ============================================

# DeepSeek API（必填）
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 可选调优
LLM_TEMPERATURE=0.15
LLM_MAX_TOKENS=2048
RETRIEVAL_MIN_SCORE=0.20
CHUNK_SIZE=800
CHUNK_OVERLAP=200
