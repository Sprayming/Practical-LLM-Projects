# =+= MODIFIED 2026-07-14 by Codex =+=
# Added: REDIS_URL, MEMORY_SHORT_TTL, MEMORY_MID_TTL, MEMORY_RETRIEVAL_THRESHOLD
# Original: .env.example.orig
# =+=
# LLM 配置
LLM_API_KEY=sk-your-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# Embedding 模型
EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./chroma_db

# 文档存储路径
DOCUMENTS_DIR=./data

# Redis 配置（可选，不配置则使用内存存储）
REDIS_URL=redis://localhost:6379/0

# 记忆系统配置
MEMORY_SHORT_TTL=7200          # 短期记忆过期时间（秒）
MEMORY_MID_TTL=86400           # 中期记忆过期时间（秒）
MEMORY_RETRIEVAL_THRESHOLD=0.25 # 长期记忆检索相似度阈值