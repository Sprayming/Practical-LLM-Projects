# Added: REDIS_URL, MEMORY_SHORT_TTL, MEMORY_MID_TTL, MEMORY_RETRIEVAL_THRESHOLD
# Original: .env.example.orig
# =+=
# LLM 配置
LLM_API_KEY=sk-your-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# Embedding 模型
EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./chroma_db

# 文档存储路径
DOCUMENTS_DIR=./data

# Redis 配置（可选，不配置则使用内存存储）
REDIS_URL=redis://localhost:6379/0

# 记忆系统配置
MEMORY_SHORT_TTL=7200          # 短期记忆过期时间（秒）
MEMORY_MID_TTL=86400           # 中期记忆过期时间（秒）
MEMORY_RETRIEVAL_THRESHOLD=0.25 # 长期记忆检索相似度阈值
# 遗忘机制配置
MEMORY_FORGETTING_THRESHOLD=0.15          # 记忆遗忘阈值（低于此值自动清理）

# Worker 配置
WORKER_NUM=2                               # 影子 Worker 线程数
# Docker 部署说明：
# 1. 复制 .env.example 为 .env，填入 LLM_API_KEY
# 2. 运行: docker compose up -d
# 3. 访问: http://localhost:8501
# 注意: Docker 部署时 REDIS_URL 会自动指向 redis 容器
#       LLM_API_KEY 必须配置，否则 AI 功能不可用